{
  "name": "@ssml-utilities/editor-react",
  "version": "0.10.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jabelic",
  "private": false,
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pkg:build": "vite build",
    "preview": "vite preview",
    "test": "pnpm --filter @ssml-utilities/core build && pnpm --filter @ssml-utilities/validation build && pnpm --filter @ssml-utilities/highlighter build && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run pkg:build"
  },
  "dependencies": {
    "@ssml-utilities/highlighter": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.3.6",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
