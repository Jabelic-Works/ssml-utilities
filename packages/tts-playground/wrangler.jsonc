{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ssml-utilities-tts-playground",
  "compatibility_date": "2026-03-15",
  "main": "./worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
