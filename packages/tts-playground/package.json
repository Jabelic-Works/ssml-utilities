{
  "name": "@ssml-utilities/tts-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-types": "wrangler types",
    "type-check": "pnpm run generate-types && vue-tsc -b",
    "build": "pnpm --filter @ssml-utilities/accent-ir build && pnpm run type-check && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:worker": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "echo 'No tests specified for tts-playground'"
  },
  "dependencies": {
    "@ssml-utilities/accent-ir": "workspace:*",
    "@ssml-utilities/analyze-contract": "workspace:*",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.73.0"
  }
}
