{
  "name": "@ssml-utilities/accent-ir",
  "version": "0.1.0",
  "description": "AccentIR-based SSML emitters for Azure and Google TTS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "type": "module",
  "types": "./dist/index.d.mts",
  "author": "Jabelic",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ssml",
    "accent",
    "tts",
    "azure",
    "google"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jabelic-works/ssml-utilities.git",
    "directory": "packages/accent-ir"
  },
  "bugs": {
    "url": "https://github.com/jabelic-works/ssml-utilities/issues"
  },
  "homepage": "https://github.com/jabelic-works/ssml-utilities/tree/main/packages/accent-ir#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "tsdown": "^0.21.6",
    "vitest": "^2.1.1"
  }
}
